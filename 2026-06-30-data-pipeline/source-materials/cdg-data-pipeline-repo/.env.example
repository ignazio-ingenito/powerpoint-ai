AWS_ACCOUNT_ID=999999999999
AWS_CDG_BUCKET=cdg-app-xls
AWS_REGION=eu-central-1

JIRA_API_TOKEN=replace-me
JIRA_BASE_URL=https://your-domain.atlassian.net
JIRA_EMAIL=your-email@example.com

MARIADB_DATABASE=p-cdgapp
MARIADB_HOST=your-mariadb-host.example.com
MARIADB_PORT=3306
MARIADB_USER=lab
MARIADB_PASSWORD=replace-me

# Local Metabase container metadata DB.
# Use the same encryption key as the deployed Metabase service when attaching to
# an existing Metabase metadata database.
METABASE_DATABASE=p-cdgapp-metabase
METABASE_ENCRYPTION_SECRET_KEY=replace-me

# Dagster's MySQL storage uses mysql-connector-python, which attempts SSL by default.
# Keep this true for MariaDB endpoints that do not support TLS; set false only when TLS is required.
DAGSTER_MYSQL_SSL_DISABLED=true
# Optional override. Use this when credentials contain URL-reserved characters and URL-encode them.
# DAGSTER_MYSQL_URL=mysql+mysqlconnector://lab:replace-me@your-mariadb-host.example.com:3306/p-cdgapp?ssl_disabled=true

TEMPO_API_TOKEN=replace-me
TEMPO_BASE_URL=https://api.tempo.io/4

REF_MAPPING_CONFIG=input/config/xls_mappings_index.yaml
REF_MAPPING_DIR=input/config


# Business scope: all non-Done issues plus recently resolved Done issues.
# Keep JIRA_MAX_RESULTS empty only when this JQL is sufficiently bounded.
JIRA_ISSUE_JQL=statusCategory != Done OR resolved >= -180d ORDER BY updated DESC
JIRA_MAX_RESULTS=
JIRA_PAGE_SIZE=100
JIRA_REQUEST_TIMEOUT=180

API_REQUEST_RETRIES=3
API_RETRY_BACKOFF_SECONDS=10

CONFLUENCE_BASE_URL=https://your-domain.atlassian.net/wiki
CONFLUENCE_EMAIL=your-email@example.com
CONFLUENCE_API_TOKEN=replace-me
